{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "omgrod.localize",
	"name": "Localize",
	"version": "v1.0.0",
	"developer": "OmgRod",
	"description": "This mod adds translations into the game.",
	"resources": {
		"files": [
			"res/translations/gd/*.json",
			"res/translations/geode/*.json",
			"res/translations/mods/*.json",
			"res/fonts/*.png",
			"res/fonts/*.fnt"
		],
		"sprites": [
			"res/sprites/**/*.png"
		]
	},
	"settings": {
		"language": {
			"name": "Language",
			"description": "Select the language you want to translate the game to.",
			"type": "custom:dropdown",
			"one-of": ["English", "Spanish", "French", "Portuguese", "Russian", "Italian", "Ukrainian", "Bulgarian", "Serbian (Latin)", "Polish"],
			"default": "English"
		}
	},
	"early-load": true,
	"dependencies": {
		"geode.node-ids": ">=1.23.3",
		"alphalaneous.alphas_geode_utils": ">=1.2.5"
	},
	"api": {
		"include": [
			"include/*.hpp"
		]
	},
	"links": {
		"community": "https://discord.gg/vK3DuqJwyW",
		"homepage": "https://localizegd.omgrod.me/",
		"source": "https://github.com/OmgRod/localize-gd/"
	},
	"tags": ["api", "content", "customization", "enhancement", "interface", "offline", "universal"]
}
