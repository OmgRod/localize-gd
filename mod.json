{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "omgrod.localize",
	"name": "Localize",
	"version": "v1.0.0",
	"developer": "OmgRod",
	"description": "This mod adds translations into the game.",
	"resources": {
		"files": [
			"res/translations/*.json",
			"res/fonts/*.png",
			"res/fonts/*.fnt"
		],
		"sprites": [
			"res/sprites/**/*.png"
		]
	},
	"settings": {
		"language": {
			"name": "Language",
			"description": "Select the language you want to translate the game to.",
			"type": "string",
			"one-of": ["English", "Spanish", "French", "Portuguese", "Russian", "Italian", "Ukrainian", "Bulgarian", "Serbian", "Polish"],
			"default": "English"
		}
	},
	"early-load": true
}
